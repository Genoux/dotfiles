#!/bin/bash
# Manage Hyprland state across sleep/resume cycles.
#
# The session lock (Quickshell ext-session-lock-v1 client) must NOT be killed before
# sleep — killing the lock client causes the Hyprland "OOPSI" compositor fallback screen.
# Unlike the old hyprlock EGL workaround, the Quickshell lock survives suspend without
# GPU context corruption, so no pre-sleep kill is needed.

HYPR_USER=$(ps aux | grep "[H]yprland" | grep -v grep | awk '{print $1}' | head -1)

case "$1" in
    pre)
        ;;
    post)
        if [ "$2" = "hibernate" ]; then
            # After hibernate: GPU state is too corrupted, restart Hyprland compositor.
            if [ -n "$HYPR_USER" ]; then
                pkill -u "$HYPR_USER" Hyprland
            fi
        fi
        # Regular suspend: hypridle's after_sleep_cmd handles lock restart if needed.
        ;;
esac
