# AMD GPU Power Management Rules
# Automatically set AMD GPU to power-saving mode for better battery life

# AMD GPU power management
ACTION=="add", SUBSYSTEM=="pci", ATTR{vendor}=="0x1002", ATTR{power/control}="auto"

# AMD GPU DPM attributes only exist on the card device, not connector children.
ACTION=="add", SUBSYSTEM=="drm", KERNEL=="card[0-9]*", ATTRS{vendor}=="0x1002", TEST=="device/power_dpm_force_performance_level", ATTR{device/power_dpm_force_performance_level}="auto"
ACTION=="add", SUBSYSTEM=="drm", KERNEL=="card[0-9]*", ATTRS{vendor}=="0x1002", TEST=="device/power_dpm_state", ATTR{device/power_dpm_state}="battery"
