{
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "claudeCode.preferredLocation": "panel",
  "window.dialogStyle": "custom",
  "window.confirmBeforeClose": "always",
  "files.simpleDialog.enable": false,
  "workbench.iconTheme": "material-icon-theme",
  "window.commandCenter": true,
  "editor.fontFamily": "JetBrainsMono Nerd Font Prono, JetBrainsMono Nerd Font",
  "window.titleBarStyle": "custom",
  "window.customMenuBarAltFocus": false,
  "window.menuBarVisibility": "hidden",
  "terminal.integrated.allowMnemonics": false,
  "console-ninja.featureSet": "Community",
  "cursor.cpp.disabledLanguages": [
    "markdown",
    "plaintext"
  ],
  "workbench.editor.enablePreview": false,
  "explorer.confirmDelete": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },

  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "workbench.list.smoothScrolling": true,

  "editor.minimap.enabled": false,
  "editor.largeFileOptimizations": true,

  "telemetry.telemetryLevel": "off",
  "update.mode": "manual",
  "extensions.autoCheckUpdates": false,
  "extensions.autoUpdate": false,

  "git.autoRepositoryDetection": "subFolders",
  "search.followSymlinks": false,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.next/**": true,
    "**/build/**": true
  },

  "typescript.tsserver.maxTsServerMemory": 4096,
  "[scss]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "workbench.editorAssociations": {
    "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
    "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.ui": "default",
    "*.qrc": "qt-core.qrcEditor",
    "*.svg": "default"
  },
  "qt-core.additionalQtPaths": [
    {
      "name": "Qt-5.15.18-linux-g++_from_PATH",
      "path": "/usr/bin/qtpaths"
    }
  ],
  "window.autoDetectColorScheme": false,
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "[qml]": {
    "editor.defaultFormatter": "Delgan.qml-format"
  },
  "diffEditor.useInlineViewWhenSpaceIsLimited": false
}
