{
  "name": "Matugen Material You",
  "type": "dark",
  "colors": {
    "editor.background": "{{colors.surface.default.hex}}",
    "editor.foreground": "{{colors.on_surface.default.hex}}",
    "editor.selectionBackground": "{{colors.primary_container.default.hex}}",
    "editor.selectionForeground": "{{colors.on_primary_container.default.hex}}",
    "editor.lineHighlightBackground": "{{colors.surface_container.default.hex}}",
    "editorCursor.foreground": "{{colors.primary.default.hex}}",
    "editorWhitespace.foreground": "{{colors.outline_variant.default.hex}}",
    "editorIndentGuide.background1": "{{colors.outline_variant.default.hex}}",
    "editorLineNumber.foreground": "{{colors.on_surface_variant.default.hex}}",
    "editorLineNumber.activeForeground": "{{colors.primary.default.hex}}",

    "activityBar.background": "{{colors.surface_container.default.hex}}",
    "activityBar.foreground": "{{colors.on_surface.default.hex}}",
    "activityBar.activeBorder": "{{colors.primary.default.hex}}",
    "activityBarBadge.background": "{{colors.primary.default.hex}}",
    "activityBarBadge.foreground": "{{colors.on_primary.default.hex}}",

    "sideBar.background": "{{colors.surface_container_low.default.hex}}",
    "sideBar.foreground": "{{colors.on_surface.default.hex}}",
    "sideBarSectionHeader.background": "{{colors.surface_container.default.hex}}",
    "sideBarSectionHeader.foreground": "{{colors.on_surface.default.hex}}",

    "statusBar.background": "{{colors.surface_container.default.hex}}",
    "statusBar.foreground": "{{colors.on_surface.default.hex}}",
    "statusBar.noFolderBackground": "{{colors.surface_container.default.hex}}",
    "statusBarItem.remoteBackground": "{{colors.primary.default.hex}}",
    "statusBarItem.remoteForeground": "{{colors.on_primary.default.hex}}",

    "titleBar.activeBackground": "{{colors.surface.default.hex}}",
    "titleBar.activeForeground": "{{colors.on_surface.default.hex}}",
    "titleBar.inactiveBackground": "{{colors.surface_dim.default.hex}}",

    "tab.activeBackground": "{{colors.surface.default.hex}}",
    "tab.activeForeground": "{{colors.on_surface.default.hex}}",
    "tab.inactiveBackground": "{{colors.surface_container_low.default.hex}}",
    "tab.inactiveForeground": "{{colors.on_surface_variant.default.hex}}",
    "tab.activeBorderTop": "{{colors.primary.default.hex}}",

    "panel.background": "{{colors.surface.default.hex}}",
    "panel.border": "{{colors.outline_variant.default.hex}}",
    "panelTitle.activeForeground": "{{colors.primary.default.hex}}",

    "terminal.background": "{{colors.surface.default.hex}}",
    "terminal.foreground": "{{colors.on_surface.default.hex}}",
    "terminal.ansiBlack": "{{colors.surface.default.hex}}",
    "terminal.ansiRed": "{{colors.error.default.hex}}",
    "terminal.ansiGreen": "{{colors.primary.default.hex}}",
    "terminal.ansiYellow": "{{colors.tertiary.default.hex}}",
    "terminal.ansiBlue": "{{colors.primary.default.hex}}",
    "terminal.ansiMagenta": "{{colors.secondary.default.hex}}",
    "terminal.ansiCyan": "{{colors.tertiary_container.default.hex}}",
    "terminal.ansiWhite": "{{colors.on_surface.default.hex}}",
    "terminal.ansiBrightBlack": "{{colors.surface_container_highest.default.hex}}",
    "terminal.ansiBrightRed": "{{colors.error.default.hex}}",
    "terminal.ansiBrightGreen": "{{colors.primary.default.hex}}",
    "terminal.ansiBrightYellow": "{{colors.tertiary.default.hex}}",
    "terminal.ansiBrightBlue": "{{colors.primary.default.hex}}",
    "terminal.ansiBrightMagenta": "{{colors.secondary.default.hex}}",
    "terminal.ansiBrightCyan": "{{colors.tertiary.default.hex}}",
    "terminal.ansiBrightWhite": "{{colors.on_surface.default.hex}}",

    "button.background": "{{colors.primary.default.hex}}",
    "button.foreground": "{{colors.on_primary.default.hex}}",
    "button.hoverBackground": "{{colors.primary_container.default.hex}}",

    "input.background": "{{colors.surface_container_high.default.hex}}",
    "input.foreground": "{{colors.on_surface.default.hex}}",
    "input.border": "{{colors.outline.default.hex}}",
    "inputOption.activeBackground": "{{colors.primary_container.default.hex}}",

    "focusBorder": "{{colors.primary.default.hex}}",
    "selection.background": "{{colors.primary_container.default.hex}}",
    "list.activeSelectionBackground": "{{colors.primary_container.default.hex}}",
    "list.activeSelectionForeground": "{{colors.on_primary_container.default.hex}}",
    "list.hoverBackground": "{{colors.surface_container_high.default.hex}}",
    "list.focusBackground": "{{colors.surface_container_highest.default.hex}}",

    "scrollbarSlider.background": "{{colors.outline_variant.default.hex}}80",
    "scrollbarSlider.hoverBackground": "{{colors.outline.default.hex}}",

    "badge.background": "{{colors.primary.default.hex}}",
    "badge.foreground": "{{colors.on_primary.default.hex}}",

    "notificationCenter.border": "{{colors.outline_variant.default.hex}}",
    "notifications.background": "{{colors.surface_container_high.default.hex}}",
    "notifications.foreground": "{{colors.on_surface.default.hex}}"
  },
  "tokenColors": [
    { "scope": ["comment"], "settings": { "foreground": "{{colors.on_surface_variant.default.hex}}", "fontStyle": "italic" } },
    { "scope": ["string"], "settings": { "foreground": "{{colors.tertiary.default.hex}}" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "{{colors.secondary.default.hex}}" } },
    { "scope": ["constant.language"], "settings": { "foreground": "{{colors.error.default.hex}}" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "{{colors.primary.default.hex}}" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "{{colors.primary_fixed.default.hex}}" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "{{colors.on_surface.default.hex}}" } },
    { "scope": ["entity.name.class", "entity.name.type", "support.class"], "settings": { "foreground": "{{colors.tertiary_fixed.default.hex}}" } },
    { "scope": ["punctuation"], "settings": { "foreground": "{{colors.on_surface_variant.default.hex}}" } }
  ]
}
