#!/usr/bin/env python3
import contextlib
import datetime as dt
import fcntl
import os
import re
import subprocess
import sys
import tempfile
import time
import urllib.request
from pathlib import Path


LEGACY_MARKER_PREFIX = "[gcal:"
CACHE_TTL_SECONDS = 15 * 60
GENERATED_APTS_FILE = "generated-apts"
RECURRENCE_RANGE_PATTERN = re.compile(
    r"^(?P<start>\d{2}/\d{2}/\d{4}).*\{[^}]* -> (?P<end>\d{2}/\d{2}/\d{4})"
)


def config_dir() -> Path:
    return Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "calcurse"


def data_dir() -> Path:
    legacy_dir = Path.home() / ".calcurse"
    if legacy_dir.exists():
        return legacy_dir

    return Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local/share")) / "calcurse"


def read_feeds(path: Path) -> list[tuple[str, str]]:
    feeds = []
    if not path.exists():
        return feeds

    for line in path.read_text().splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue

        name, url = stripped.split(maxsplit=1)
        feeds.append((name, url))

    return feeds


def unfold_ical_lines(text: str) -> list[str]:
    unfolded = []
    for line in text.replace("\r\n", "\n").replace("\r", "\n").split("\n"):
        if line.startswith((" ", "\t")) and unfolded:
            unfolded[-1] += line[1:]
        else:
            unfolded.append(line)

    return unfolded


def fold_ical_line(line: str) -> list[str]:
    encoded = line.encode()
    if len(encoded) <= 75:
        return [line]

    folded = []
    current = ""
    for character in line:
        candidate = current + character
        limit = 75 if not folded else 74
        if len(candidate.encode()) > limit:
            folded.append(current if not folded else f" {current}")
            current = character
        else:
            current = candidate

    if current:
        folded.append(current if not folded else f" {current}")

    return folded


def uid_from_event(event_lines: list[str]) -> str | None:
    for line in event_lines:
        if line.startswith("UID"):
            return line.split(":", 1)[1] if ":" in line else None

    return None


def iter_events(lines: list[str]) -> list[list[str]]:
    events = []
    current = None
    for line in lines:
        if line == "BEGIN:VEVENT":
            current = [line]
        elif current is not None:
            current.append(line)
            if line == "END:VEVENT":
                events.append(current)
                current = None

    return events


def build_import_ics(feeds: list[tuple[str, str]], cache_dir: Path, log_file: Path) -> str:
    header = [
        "BEGIN:VCALENDAR",
        "PRODID:-//dotfiles//calcurse google feed sync//EN",
        "VERSION:2.0",
        "CALSCALE:GREGORIAN",
    ]
    footer = ["END:VCALENDAR"]
    events = []
    seen_uids = set()

    for feed_name, url in feeds:
        cache_file = cache_dir / f"{feed_name}.ics"
        should_fetch = not cache_file.exists() or time.time() - cache_file.stat().st_mtime > CACHE_TTL_SECONDS

        if should_fetch:
            try:
                with urllib.request.urlopen(url, timeout=20) as response:
                    cache_file.write_bytes(response.read())
            except Exception as error:
                with log_file.open("a") as log:
                    log.write(f"{time.ctime()} failed to fetch {feed_name}: {error}\n")

        if not cache_file.exists():
            continue

        lines = unfold_ical_lines(cache_file.read_text(errors="replace"))
        for event in iter_events(lines):
            uid = uid_from_event(event)
            if uid and uid in seen_uids:
                continue
            if uid:
                seen_uids.add(uid)
            events.extend(event)

    output_lines = []
    for line in [*header, *events, *footer, ""]:
        output_lines.extend(fold_ical_line(line))

    return "\n".join(output_lines)


def import_ics_to_apts(ics_text: str, log_file: Path) -> tuple[str, list[tuple[str, bytes]]]:
    with tempfile.TemporaryDirectory(prefix="calcurse-ics-") as temp_root:
        root = Path(temp_root)
        data = root / "data"
        conf = root / "conf"
        notes = data / "notes"
        data.mkdir()
        conf.mkdir()
        notes.mkdir()
        (data / "apts").write_text("")
        (data / "todo").write_text("")

        ics_file = root / "feeds.ics"
        ics_file.write_text(ics_text)

        result = subprocess.run(
            ["calcurse", "-D", str(data), "-C", str(conf), "-i", str(ics_file), "-q"],
            text=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
        )

        generated = (data / "apts").read_text() if (data / "apts").exists() else ""
        if result.returncode != 0:
            with log_file.open("a") as log:
                log.write(f"{time.ctime()} calcurse import exited {result.returncode}\n")
                log.write(result.stderr)
                log.write("\n")

        generated_notes = [(note.name, note.read_bytes()) for note in notes.iterdir() if note.is_file()]
        return generated, generated_notes


def has_valid_recurrence_range(line: str) -> bool:
    match = RECURRENCE_RANGE_PATTERN.match(line)
    if not match:
        return True

    start = dt.datetime.strptime(match.group("start"), "%m/%d/%Y").date()
    end = dt.datetime.strptime(match.group("end"), "%m/%d/%Y").date()
    return end >= start


def previous_generated_lines(path: Path) -> set[str]:
    if not path.exists():
        return set()

    return set(path.read_text().splitlines())


def merge_generated_apts(
    calendar_data_dir: Path,
    state_dir: Path,
    generated_apts: str,
    generated_notes: list[tuple[str, bytes]],
) -> None:
    apts_file = calendar_data_dir / "apts"
    generated_apts_file = state_dir / GENERATED_APTS_FILE
    notes_dir = calendar_data_dir / "notes"
    notes_dir.mkdir(parents=True, exist_ok=True)
    existing_lines = apts_file.read_text().splitlines() if apts_file.exists() else []
    generated_lines = [line for line in generated_apts.splitlines() if has_valid_recurrence_range(line)]
    previous_lines = previous_generated_lines(generated_apts_file)
    local_lines = [
        line
        for line in existing_lines
        if line not in previous_lines and LEGACY_MARKER_PREFIX not in line
    ]
    merged = "\n".join([*local_lines, *generated_lines])
    apts_file.write_text(f"{merged}\n" if merged else "")
    generated_apts_file.write_text("\n".join(generated_lines) + "\n")

    for note_name, note_contents in generated_notes:
        (notes_dir / note_name).write_bytes(note_contents)


def main() -> int:
    conf_dir = config_dir()
    calendar_data_dir = data_dir()
    state_dir = calendar_data_dir / "ics-feeds"
    cache_dir = state_dir / "cache"
    log_file = state_dir / "sync.log"
    lock_file = state_dir / "sync.lock"

    state_dir.mkdir(parents=True, exist_ok=True)
    cache_dir.mkdir(parents=True, exist_ok=True)
    calendar_data_dir.mkdir(parents=True, exist_ok=True)

    feeds = read_feeds(conf_dir / "ics-feeds")
    if not feeds:
        return 0

    with lock_file.open("w") as lock:
        try:
            fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            return 0

        ics_text = build_import_ics(feeds, cache_dir, log_file)
        if "BEGIN:VEVENT" not in ics_text:
            return 0

        generated_apts, generated_notes = import_ics_to_apts(ics_text, log_file)
        if generated_apts.strip():
            merge_generated_apts(calendar_data_dir, state_dir, generated_apts, generated_notes)

    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception as error:
        with contextlib.suppress(Exception):
            fallback_state_dir = data_dir() / "ics-feeds"
            fallback_state_dir.mkdir(parents=True, exist_ok=True)
            with (fallback_state_dir / "sync.log").open("a") as log:
                log.write(f"{time.ctime()} sync failed: {error}\n")
    sys.exit(0)
