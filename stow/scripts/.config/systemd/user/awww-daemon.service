[Unit]
Description=An Answer to your Wayland Wallpaper Woes (awww-daemon)
Documentation=man:awww-daemon(1)
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/awww-daemon
Restart=on-failure
RestartSec=3
KillMode=mixed
TimeoutStopSec=5

[Install]
WantedBy=graphical-session.target
