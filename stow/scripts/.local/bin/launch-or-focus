#!/usr/bin/env bash
# Generic launcher with single-instance support
# Usage: launch-or-focus TITLE COMMAND [CLASS] [ARGS...]

TITLE="${1:?Usage: launch-or-focus TITLE COMMAND [CLASS] [ARGS...]}"
COMMAND="${2:?Usage: launch-or-focus TITLE COMMAND [CLASS] [ARGS...]}"
shift 2
if [ $# -gt 0 ]; then
    CLASS="$1"
    shift 1
else
    CLASS="$TITLE"
fi
EXTRA_ARGS=("$@")

lua_string() {
    jq -Rn --arg value "$1" '$value'
}

# If we're in display mode, run the TUI cleanly
if [ "$LAUNCH_OR_FOCUS_DISPLAY" = "1" ]; then
    tput clear
    tput civis

    "$COMMAND" "${EXTRA_ARGS[@]}"

    stty -echo
    read -n 1 -s
    stty echo

    tput cnorm
    exit 0
fi

lua_args="$(lua_string "$TITLE"), $(lua_string "$COMMAND"), $(lua_string "$CLASS")"
for arg in "${EXTRA_ARGS[@]}"; do
    lua_args+=", $(lua_string "$arg")"
done

hyprctl dispatch "function() require('actions.launchers').launchOrFocus($lua_args) end"
